# Post-graduation (Phase 5), upgrade to contents:write to enable auto-commit.
GITHUB_TOKEN=ghp_
GITHUB_REPO=bcali/roadmap-dashboard
GITHUB_BRANCH=main

# --- Agent config ---
TIMEZONE=Asia/Bangkok
RUN_TIME=00:00
ACCURACY_THRESHOLD=0.90
AUDIT_RETENTION_DAYS=30

