# --- Claude ---
ANTHROPIC_API_KEY=sk-ant-

# --- GitHub: the dashboard repo the agent reads context from AND commits input files to ---
# Fine-grained PAT scoped to bcali/roadmap-dashboard with contents:read AND contents:write.
GITHUB_TOKEN=ghp_
GITHUB_REPO=bcali/roadmap-dashboard
GITHUB_BRANCH=main

# --- Microsoft 365 sources (active): Outlook → emails.md, Teams → meetings.md ---
# From the Azure AD app registration (Minor IT). App-only Graph permissions:
# Mail.Read + OnlineMeetingTranscript.Read.All, with admin consent.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_USER_ID=            # your UPN / object id (the mailbox + meetings owner)

# --- Agent ---
TIMEZONE=Asia/Bangkok

# --- Confluence source (parked — revive when it's active again) ---
# ATLASSIAN_EMAIL=
# ATLASSIAN_API_TOKEN=

# --- Slack source (active): tracked channels → notes.md ---
# Bot token (xoxb-) with scopes: channels:history (public) + groups:history (private).
# The bot must be invited to each channel listed in config/agent-config.json → slack.channels.
# Producer no-ops if this is unset OR slack.channels is empty.
SLACK_BOT_TOKEN=xoxb-

# --- Failure alerts (incoming webhook for ops alerts) ---
# SLACK_ALERTS_WEBHOOK=https://hooks.slack.com/services/...
